<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Login | ResolveStation</title>

    <link rel="stylesheet" href="/css/auth.css" />

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
  </head>

  <body>
    <div class="auth-wrapper">
      <div class="auth-shape auth-shape-1"></div>

      <div class="auth-shape auth-shape-2"></div>

      <div class="auth-shape auth-shape-3"></div>

      <div class="auth-container">
        <!-- ===================================== -->
        <!-- HERO -->
        <!-- ===================================== -->

        <div class="auth-hero">
          <a href="/">
            <img
              src="/images/logo/resolvestationlogo.svg"
              alt="ResolveStation Logo"
              class="auth-logo-login"
            />
          </a>

          <h1>
            Login to

            <span> ResolveStation </span>
          </h1>

          <p>
            Securely manage maintenance requests, complaints, residents and
            staff from one centralized platform.
          </p>

          <div class="auth-features">
            <div class="feature-item">
              <i class="bi bi-buildings-fill"></i>

              Resident Management
            </div>

            <div class="feature-item">
              <i class="bi bi-tools"></i>

              Maintenance Tracking
            </div>
          </div>
        </div>

        <!-- ===================================== -->
        <!-- LOGIN CARD -->
        <!-- ===================================== -->

        <div class="auth-card auth-card-login">
          <div class="auth-header">
            <h2 class="login-head-c">ResolveStation</h2>

            <p>Login to continue</p>
          </div>

          <form
            id="loginForm"
            class="auth-form"
            action="/api/auth/login"
            method="POST"
          >
            <!-- EMAIL -->

            <div class="form-group">
              <label class="form-label"> Email Address </label>

              <div class="form-input-wrapper">
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="form-input"
                  placeholder="Enter your email"
                />
              </div>

              <p class="form-error" id="emailError"></p>
            </div>

            <!-- PASSWORD -->

            <div class="form-group">
              <label class="form-label"> Password </label>

              <div class="form-input-wrapper">
                <input
                  type="password"
                  id="password"
                  name="password"
                  class="form-input"
                  placeholder="Enter your password"
                />

                <button type="button" class="password-toggle">
                  <i class="bi bi-eye-slash"></i>
                </button>
              </div>

              <p class="form-error" id="passwordError"></p>
            </div>

            <!-- OPTIONS -->

            <div class="checkbox-group">
              <label class="checkbox-label">
                <input type="checkbox" id="rememberMe" name="rememberMe" />

                Remember Me
              </label>

              <a href="/auth/forgot-password" class="auth-link">
                Forgot Password?
              </a>
            </div>

            <!-- BUTTON -->

            <button
              type="submit"
              class="auth-btn auth-btn-primary auth-btn-full"
            >
              Login
            </button>
          </form>

          <!-- FOOTER -->

          <div class="auth-footer">
            Don't have an account?

            <a href="/auth/register" class="auth-link"> Register </a>
          </div>
        </div>
      </div>
    </div>

    <div id="toast-container" class="toast-container"></div>

    <script src="/js/toast.js"></script>

    <script src="/js/auth.js"></script>
  </body>
</html>
