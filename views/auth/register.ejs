<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Create Account | ResolveStation</title>

    <link rel="stylesheet" href="/css/auth.css" />

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
  </head>

  <body>
    <div class="auth-wrapper">
      <div class="auth-shape auth-shape-1"></div>

      <div class="auth-shape auth-shape-2"></div>

      <div class="auth-shape auth-shape-3"></div>

      <div class="auth-container">
        <!-- ===================================== -->
        <!-- HERO -->
        <!-- ===================================== -->

        <div class="auth-hero">
          <div class="brand-logo">
            <a href="/">
              <img
                src="/images/logo/resolvestationlogo.svg"
                alt="ResolveStation Logo"
                class="auth-logo-login"
              />
            </a>
          </div>
          <h1>
            Join

            <span> ResolveStation </span>
          </h1>

          <p>
            Create your account and start managing complaints, maintenance
            requests and community services from one place.
          </p>

          <div class="auth-features">
            <div class="feature-item">
              <i class="bi bi-shield-check"></i>

              Secure Authentication
            </div>

            <div class="feature-item">
              <i class="bi bi-tools"></i>

              Maintenance Tracking
            </div>

            <div class="feature-item">
              <i class="bi bi-chat-dots"></i>

              Complaint Management
            </div>

            <div class="feature-item">
              <i class="bi bi-bell"></i>

              Real-Time Notifications
            </div>
          </div>
        </div>

        <!-- ===================================== -->
        <!-- REGISTER CARD -->
        <!-- ===================================== -->

        <div class="auth-card">
          <div class="main-c-head"><h2>ResolveStation</h2></div>
          <div class="auth-header">
            <h2>Create Account</h2>

            <p>Fill in your information below</p>
          </div>

          <form
            id="registerForm"
            class="auth-form"
            method="POST"
            action="/api/auth/register"
          >
            <!-- NAME -->

            <div class="form-group">
              <label class="form-label"> Full Name </label>

              <div class="form-input-wrapper">
                <input
                  type="text"
                  id="name"
                  name="name"
                  class="form-input"
                  placeholder="Enter full name"
                />

                <i class="fas fa-user form-icon"></i>
              </div>

              <p class="form-error" id="nameError"></p>
            </div>

            <!-- EMAIL -->

            <div class="form-group">
              <label class="form-label"> Email Address </label>

              <div class="form-input-wrapper">
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="form-input"
                  placeholder="Enter email address"
                />

                <i class="fas fa-envelope form-icon"></i>
              </div>

              <p class="form-error" id="emailError"></p>
            </div>

            <!-- PASSWORD -->

            <div class="form-group">
              <label class="form-label"> Password </label>

              <div class="form-input-wrapper">
                <input
                  type="password"
                  id="password"
                  name="password"
                  class="form-input"
                  placeholder="Create password"
                />

                <button type="button" class="password-toggle">
                  <i class="bi bi-eye-slash"></i>
                </button>
              </div>

              <p class="form-error" id="passwordError"></p>

              <!-- STRENGTH -->

              <div class="password-strength">
                <div class="password-strength-text">
                  <span> Password Strength </span>

                  <span id="strengthText"> Weak </span>
                </div>

                <div class="password-strength-bar">
                  <div
                    id="strengthFill"
                    class="password-strength-fill strength-weak"
                  ></div>
                </div>
              </div>

              <!-- RULES -->

              <div class="password-rules">
                <div id="rule-length" class="password-rule">
                  <i class="bi bi-x-circle"></i>

                  8+ Characters
                </div>

                <div id="rule-upper" class="password-rule">
                  <i class="bi bi-x-circle"></i>

                  Uppercase Letter
                </div>

                <div id="rule-lower" class="password-rule">
                  <i class="bi bi-x-circle"></i>

                  Lowercase Letter
                </div>

                <div id="rule-number" class="password-rule">
                  <i class="bi bi-x-circle"></i>

                  Number
                </div>

                <div id="rule-special" class="password-rule">
                  <i class="bi bi-x-circle"></i>

                  Special Character
                </div>
              </div>
            </div>

            <!-- CONFIRM PASSWORD -->

            <div class="form-group">
              <label class="form-label"> Confirm Password </label>

              <div class="form-input-wrapper">
                <input
                  type="password"
                  id="confirmPassword"
                  name="confirmPassword"
                  class="form-input"
                  placeholder="Confirm password"
                />

                <button type="button" class="password-toggle">
                  <i class="bi bi-eye-slash"></i>
                </button>
              </div>

              <p class="form-error" id="confirmPasswordError"></p>
            </div>

            <!-- TERMS -->

            <div class="checkbox-group">
              <label class="checkbox-label">
                <input type="checkbox" id="terms" required />

                I agree to the Terms & Conditions
              </label>
            </div>

            <!-- BUTTON -->

            <button
              type="submit"
              class="auth-btn auth-btn-primary auth-btn-full"
            >
              Create Account
            </button>
          </form>

          <div class="auth-footer">
            Already have an account?

            <a href="/auth/login" class="auth-link"> Login </a>
          </div>
        </div>
      </div>
    </div>

    <div id="toast-container" class="toast-container"></div>

    <script src="/js/toast.js"></script>

    <script src="/js/auth.js"></script>
  </body>
</html>
