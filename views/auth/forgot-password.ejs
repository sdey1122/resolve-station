<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Forgot Password | ResolveStation</title>

    <link rel="stylesheet" href="/css/auth.css" />

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
  </head>

  <body>
    <div class="auth-wrapper">
      <div class="auth-shape auth-shape-1"></div>

      <div class="auth-shape auth-shape-2"></div>

      <div class="auth-shape auth-shape-3"></div>

      <div class="auth-container">
        <!-- HERO -->

        <div class="auth-hero">
          <a href="/">
            <img
              src="/images/logo/resolvestationlogo.svg"
              alt="ResolveStation"
              class="auth-logo-login"
            />
          </a>

          <h1>
            Forgot Your

            <span> Password? </span>
          </h1>

          <p>
            Don't worry. Enter your registered email address and we'll send you
            a secure password reset link.
          </p>

          <div class="auth-features">
            <div class="feature-item">
              <i class="bi bi-shield-lock-fill"></i>

              Secure Recovery
            </div>

            <div class="feature-item">
              <i class="bi bi-envelope-check-fill"></i>

              Email Verification
            </div>

            <div class="feature-item">
              <i class="bi bi-key-fill"></i>

              Password Protection
            </div>
          </div>
        </div>

        <!-- CARD -->

        <div class="auth-card">
          <div class="auth-header">
            <h2 class="login-head-c">ResolveStation</h2>
            <h2>Forgot Password</h2>

            <p>Enter your email address</p>
          </div>

          <form id="forgotPasswordForm" class="auth-form">
            <div class="form-group">
              <label class="form-label"> Email Address </label>

              <div class="form-input-wrapper">
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="form-input"
                  placeholder="Enter your email"
                />

                <i class="bi bi-envelope-fill form-icon"></i>
              </div>

              <p id="emailError" class="form-error"></p>
            </div>

            <button
              type="submit"
              class="auth-btn auth-btn-primary auth-btn-full"
            >
              Send Reset Link
            </button>
          </form>

          <div class="auth-footer">
            Remember your password?

            <a href="/auth/login" class="auth-link"> Login </a>
          </div>
        </div>
      </div>
    </div>

    <div id="toast-container" class="toast-container"></div>

    <script src="/js/toast.js"></script>

    <script src="/js/auth.js"></script>
  </body>
</html>
