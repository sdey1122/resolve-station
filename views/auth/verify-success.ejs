<!DOCTYPE html>

<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Email Verified | ResolveStation</title>

    <link rel="stylesheet" href="/css/verify.css" />

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
  </head>

  <body>
    <div class="verify-page">
      <div class="verify-bg verify-bg-1"></div>

      <div class="verify-bg verify-bg-2"></div>

      <div class="verify-card">
        <div class="verify-icon success">
          <i class="bi bi-patch-check-fill"></i>
        </div>

        <h1>Email Verified Successfully</h1>

        <p>
          Congratulations! Your ResolveStation account has been verified and
          activated. You can now securely log in and access all platform
          features.
        </p>

        <a href="/auth/login" class="verify-btn">
          <i class="bi bi-box-arrow-in-right"></i>

          Login Now
        </a>
      </div>
    </div>
  </body>
</html>
