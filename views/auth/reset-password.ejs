<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Reset Password | ResolveStation</title>

    <link rel="stylesheet" href="/css/auth.css" />

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
  </head>

  <body>
    <div class="auth-wrapper">
      <div class="auth-shape auth-shape-1"></div>

      <div class="auth-shape auth-shape-2"></div>

      <div class="auth-shape auth-shape-3"></div>

      <div class="auth-container">
        <!-- HERO -->

        <div class="auth-hero">
          <a href="/">
            <img
              src="/images/logo/resolvestationlogo.svg"
              alt="ResolveStation"
              class="auth-logo-login"
            />
          </a>

          <h1>
            Create New

            <span> Password </span>
          </h1>

          <p>Choose a strong password to keep your account safe and secure.</p>
        </div>

        <!-- CARD -->

        <div class="auth-card">
          <div><h2 class="main-c-head">ResolveStation</h2></div>

          <div class="auth-header">
            <h2>Reset Password</h2>

            <p>Enter your new password</p>
          </div>

          <form id="resetPasswordForm" class="auth-form">
            <input type="hidden" id="token" value="<%= token %>" />

            <!-- PASSWORD -->

            <div class="form-group">
              <label class="form-label"> New Password </label>

              <div class="form-input-wrapper">
                <input
                  type="password"
                  id="password"
                  class="form-input"
                  placeholder="Enter new password"
                />

                <button type="button" class="password-toggle">
                  <i class="bi bi-eye-slash"></i>
                </button>
              </div>

              <p id="passwordError" class="form-error"></p>

              <!-- STRENGTH -->

              <div class="password-strength">
                <div class="password-strength-text">
                  <span> Password Strength </span>

                  <span id="strengthText"> Weak </span>
                </div>

                <div class="password-strength-bar">
                  <div
                    id="strengthFill"
                    class="password-strength-fill strength-weak"
                  ></div>
                </div>
              </div>

              <!-- RULES -->

              <div class="password-rules">
                <div id="rule-length" class="password-rule">
                  <i class="bi bi-x-circle"></i>

                  8+ Characters
                </div>

                <div id="rule-upper" class="password-rule">
                  <i class="bi bi-x-circle"></i>

                  Uppercase Letter
                </div>

                <div id="rule-lower" class="password-rule">
                  <i class="bi bi-x-circle"></i>

                  Lowercase Letter
                </div>

                <div id="rule-number" class="password-rule">
                  <i class="bi bi-x-circle"></i>

                  Number
                </div>

                <div id="rule-special" class="password-rule">
                  <i class="bi bi-x-circle"></i>

                  Special Character
                </div>
              </div>
            </div>

            <!-- CONFIRM PASSWORD -->

            <div class="form-group">
              <label class="form-label"> Confirm Password </label>

              <div class="form-input-wrapper">
                <input
                  type="password"
                  id="confirmPassword"
                  class="form-input"
                  placeholder="Confirm password"
                />

                <button type="button" class="password-toggle">
                  <i class="bi bi-eye-slash"></i>
                </button>
              </div>

              <p id="confirmPasswordError" class="form-error"></p>
            </div>

            <button
              type="submit"
              class="auth-btn auth-btn-primary auth-btn-full"
            >
              Update Password
            </button>
          </form>

          <div class="auth-footer">
            Back to

            <a href="/auth/login" class="auth-link"> Login </a>
          </div>
        </div>
      </div>
    </div>

    <div id="toast-container" class="toast-container"></div>

    <script src="/js/toast.js"></script>

    <script src="/js/auth.js"></script>
  </body>
</html>
