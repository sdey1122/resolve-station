<!DOCTYPE html>

<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Verification Failed | ResolveStation</title>

    <link rel="stylesheet" href="/css/verify.css" />

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
  </head>

  <body>
    <div class="verify-page">
      <div class="verify-bg verify-bg-1"></div>

      <div class="verify-bg verify-bg-2"></div>

      <div class="verify-card">
        <div class="verify-icon failed">
          <i class="bi bi-x-circle-fill"></i>
        </div>

        <h1>Verification Failed</h1>

        <p><%= error || "We couldn't verify your email address." %></p>

        <div class="verify-actions">
          <a href="/auth/login" class="verify-btn">
            <i class="bi bi-box-arrow-in-right"></i>

            Back To Login
          </a>
        </div>
      </div>
    </div>
  </body>
</html>
