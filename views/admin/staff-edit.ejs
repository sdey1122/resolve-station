<!DOCTYPE html>

<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Edit Staff | ResolveStation</title>

    <link rel="stylesheet" href="/css/dashboard.css" />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
  </head>

  <body>
    <div class="dashboard-container">
      <%- include("../partials/admin-sidebar") %>

      <main class="dashboard-main">
        <%- include("../partials/dashboard-header") %>

        <!-- ===================================== -->
        <!-- PAGE HEADER -->
        <!-- ===================================== -->

        <section class="page-header">
          <div>
            <h1>
              <i class="fas fa-user-pen"></i>

              Edit Staff
            </h1>

            <p>Update staff account information.</p>
          </div>

          <div class="action-buttons">
            <a href="/admin/staff/<%= staff._id %>" class="btn btn-outline">
              <i class="fas fa-arrow-left"></i>

              Back
            </a>
          </div>
        </section>

        <!-- ===================================== -->
        <!-- EDIT FORM -->
        <!-- ===================================== -->

        <section class="content-card">
          <form
            action="/api/admin/staff/<%= staff._id %>"
            method="POST"
            enctype="multipart/form-data"
          >
            <!-- CURRENT PROFILE -->

            <div
              style="
                display: flex;
                justify-content: center;
                margin-bottom: 30px;
              "
            >
              <img
                src="<%= staff.profileImage?.url || '/images/default-avatar.png' %>"
                alt="Staff"
                class="user-avatar"
                style="width: 120px; height: 120px"
              />
            </div>

            <!-- PROFILE IMAGE -->

            <div class="form-group">
              <label> Change Profile Image </label>

              <input type="file" name="profileImage" accept="image/*" />
            </div>

            <!-- NAME -->

            <div class="form-group">
              <label> Full Name </label>

              <input
                type="text"
                name="name"
                value="<%= staff.name %>"
                required
              />
            </div>

            <!-- EMAIL -->

            <div class="form-group">
              <label> Email Address </label>

              <input
                type="email"
                name="email"
                value="<%= staff.email %>"
                required
              />
            </div>

            <!-- ACCOUNT INFO -->

            <section
              class="content-card"
              style="margin-top: 20px; margin-bottom: 20px"
            >
              <h3>Account Information</h3>

              <div class="table-wrapper">
                <table>
                  <tbody>
                    <tr>
                      <th>Role</th>

                      <td><%= staff.role %></td>
                    </tr>

                    <tr>
                      <th>Email Verification</th>

                      <td><%= staff.isVerified ? "Verified" : "Pending" %></td>
                    </tr>

                    <tr>
                      <th>Created</th>

                      <td>
                        <%= new Date( staff.createdAt ).toLocaleString() %>
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </section>

            <!-- ACTIONS -->

            <div class="action-buttons">
              <button type="submit" class="btn btn-primary">
                <i class="fas fa-floppy-disk"></i>

                Save Changes
              </button>

              <a href="/admin/staff/<%= staff._id %>" class="btn btn-outline">
                Cancel
              </a>
            </div>
          </form>
        </section>

        <%- include("../partials/dashboard-footer") %>
      </main>
    </div>

    <script src="/js/dashboard.js"></script>
  </body>
</html>
