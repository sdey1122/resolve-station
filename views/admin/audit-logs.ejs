<!DOCTYPE html>

<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <title>Audit Logs | ResolveStation</title>

    <!-- Bootstrap -->

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Bootstrap Icons -->

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
    />

    <!-- Dashboard CSS -->

    <link
      rel="stylesheet"
      href="/css/admin.css"
    />
  </head>

  <body>
    <!-- Sidebar Overlay -->

    <div
      class="sidebar-overlay"
      id="sidebarOverlay"
    ></div>

    <div class="dashboard-wrapper">

      <!-- Sidebar -->

      <aside
        class="sidebar"
        id="sidebar"
      >
        <div class="sidebar-header">
          <img
            src="/images/logo/resolvestationlogo.png"
            alt="ResolveStation"
          />
        </div>

        <nav class="sidebar-nav">

          <a
            href="/admin/dashboard"
            class="nav-link"
          >
            <i class="bi bi-grid"></i>

            <span class="nav-text">
              Dashboard
            </span>
          </a>

          <!-- ==========================================
     COMPLAINT MANAGEMENT
========================================== -->

<div class="nav-title">

    Complaint Management

</div>

<a
    href="/admin/complaints/pending"
    class="nav-link"
>

    <i class="bi bi-hourglass-split"></i>

    <span class="nav-text">

        Pending Complaints

    </span>

</a>

<div class="nav-divider"></div>

          <div class="nav-title">
            Staff Management
          </div>

           <a
            href="/admin/staff/show"
            class="nav-link"
          >
            <i class="bi bi-people"></i>

            <span class="nav-text">
              View Staff
            </span>
          </a>

          <a
            href="/admin/staff/create"
            class="nav-link"
          >
            <i class="bi bi-person-plus"></i>

            <span class="nav-text">
              Manage Staff
            </span>
          </a>

          <a href="/admin/completed-reviews" class="nav-link">
    <i class="bi bi-patch-check-fill"></i>

    <span>

        Completed Reviews

    </span>
</a>

<a href="/admin/cannot-complete-reviews" class="nav-link">
    <i class="bi bi-exclamation-octagon-fill"></i>

    <span>

        Unable To Complete

    </span>
</a>

          <div class="nav-divider"></div>

          <div class="nav-title">
            Resident Management
          </div>

          <a
            href="/admin/resident/show"
            class="nav-link"
          >
            <i class="bi bi-house-door"></i>

            <span class="nav-text">
              View Residents
            </span>
          </a>

          <div class="nav-divider"></div>

          <div class="nav-title">
            System
          </div>

          <a
            href="/admin/account-trash"
            class="nav-link"
          >
            <i class="bi bi-trash"></i>

            <span class="nav-text">
              Account Trash
            </span>
          </a>

          <a
            href="/admin/audit-logs"
            class="nav-link active"
          >
            <i class="bi bi-journal-text"></i>

            <span class="nav-text">
              Audit Logs
            </span>
          </a>

        </nav>

        <button
          class="logout-btn"
          id="logoutBtn"
        >
          <i class="bi bi-box-arrow-right"></i>

          <span class="logout-text">
            Logout
          </span>
        </button>
      </aside>

      <!-- Main Content -->

      <main
        class="main-content"
        id="mainContent"
      >

        <!-- Header -->

        <header class="dashboard-header">

          <div class="header-left">

            <button
              class="menu-toggle"
              id="menuToggle"
            >
              <i class="bi bi-list"></i>
            </button>

            <div class="welcome-section">
              <h1>
                Welcome, <%= user.name %>
              </h1>

              <p>
                Administrator • <%= user.email %>
              </p>
            </div>

          </div>

          <div class="header-right">

            <button class="notification-btn">
              <i class="bi bi-bell"></i>
            </button>

           <a
  href="/admin/profile"
  class="profile-box"
  title="My Profile"
>
  <img
    src="<%= user.profileImage?.url %>"
    alt="<%= user.name %>"
  />
</a>

          </div>

        </header>
                <!-- Hero Banner -->

        <section class="hero-banner">
          <div>
            <h2>
              Audit Logs Dashboard
            </h2>

            <p>
              Monitor all administrative activities and security events across
              ResolveStation.
            </p>
          </div>
        </section>

        <!-- Audit Logs -->

        <section class="staff-list-section">
          <div class="staff-form-card">

            <div class="form-card-header">
              <h3>
                System Audit Logs
              </h3>

              <p>
                Review administrative actions performed throughout the
                ResolveStation platform.
              </p>
            </div>

            <!-- Search + Filters -->

            <div class="staff-toolbar">

              <!-- Search -->

              <div class="search-box">
                <i class="bi bi-search search-icon"></i>

                <input
                  type="text"
                  id="searchLog"
                  placeholder="Search admin, details or action..."
                />
              </div>

              <!-- Role Filter -->

              <select
                id="roleFilter"
                class="staff-sort"
              >
                <option value="all">
                  All Roles
                </option>

                <option value="ADMIN">
                  Admin
                </option>

                <option value="STAFF">
                  Staff
                </option>

                <option value="RESIDENT">
                  Resident
                </option>
              </select>

              <!-- Action Filter -->

              <select
                id="actionFilter"
                class="staff-sort"
              >
                <option value="all">
                  All Actions
                </option>

                <option value="CREATE">
                  Created
                </option>

                <option value="UPDATE">
                  Updated
                </option>

                <option value="DELETE">
                  Deleted
                </option>

                <option value="RESTORE">
                  Restored
                </option>

                <option value="PERMANENT_DELETE">
                  Permanent Delete
                </option>
              </select>

              <!-- Sort -->

              <select
                id="sortLog"
                class="staff-sort"
              >
                <option value="newest">
                  Newest First
                </option>

                <option value="oldest">
                  Oldest First
                </option>

                <option value="az">
                  A - Z
                </option>

                <option value="za">
                  Z - A
                </option>
              </select>

            </div>
                        <!-- Audit Logs Table -->

            <div class="table-responsive">
              <table class="table staff-table">
                <thead>
                  <tr>
                    <th>Time</th>

                    <th>Admin</th>

                    <th>Action</th>

                    <!-- <th>Target</th> -->
                     <th>Details</th>

                    <th>Role</th>

                    <th>IP Address</th>
                  </tr>
                </thead>

                <tbody id="auditTableBody">
                  <!-- Dynamic Audit Logs -->
                </tbody>
              </table>
            </div>

            <!-- Pagination -->

            <div class="pagination-wrapper">
              <button
                id="prevPage"
                class="pagination-btn"
              >
                <i class="bi bi-chevron-left"></i>
              </button>

              <span id="pageInfo">
                Page 1 of 1
              </span>

              <button
                id="nextPage"
                class="pagination-btn"
              >
                <i class="bi bi-chevron-right"></i>
              </button>
            </div>

          </div>
        </section>
            <!-- Logout Modal -->

    <div
      class="logout-modal"
      id="logoutModal"
    >
      <div class="logout-modal-card">
        <div class="logout-icon">
          <i class="bi bi-box-arrow-right"></i>
        </div>

        <h3>
          Logout Confirmation
        </h3>

        <p>
          Are you sure you want to logout from ResolveStation? You will need
          to sign in again to access your dashboard.
        </p>

        <div class="logout-actions">
          <button
            class="cancel-btn"
            id="cancelLogout"
          >
            Cancel
          </button>

          <button
            class="confirm-btn"
            id="confirmLogout"
          >
            Yes, Logout
          </button>
        </div>
      </div>
    </div>

    <!-- Scripts -->

    <script src="/js/admin.js"></script>

    <script src="/js/audit-logs.js"></script>
  </body>
</html>