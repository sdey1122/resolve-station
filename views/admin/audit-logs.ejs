<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <title>
    Audit Logs | ResolveStation
  </title>

  <link
    rel="stylesheet"
    href="/css/dashboard.css"
  >

  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
  >

</head>

<body>

<div class="dashboard-container">

  <%- include("../partials/admin-sidebar") %>

  <main class="dashboard-main">

    <%- include("../partials/dashboard-header") %>

    <!-- PAGE HEADER -->

    <section class="page-header">

      <div>

        <h1>

          <i class="fas fa-shield-halved"></i>

          Audit Logs

        </h1>

        <p>

          Monitor system activities, security events and user actions.

        </p>

      </div>

    </section>

    <!-- STATS -->

    <section class="stats-grid">

      <div class="stat-card gold">

        <div class="stat-icon icon-gold">

          <i class="fas fa-file-lines"></i>

        </div>

        <h4>
          Total Logs
        </h4>

        <h2>
          <%= stats?.totalLogs || 0 %>
        </h2>

      </div>

      <div class="stat-card blue">

        <div class="stat-icon icon-blue">

          <i class="fas fa-calendar-day"></i>

        </div>

        <h4>
          Today
        </h4>

        <h2>
          <%= stats?.todayLogs || 0 %>
        </h2>

      </div>

      <div class="stat-card green">

        <div class="stat-icon icon-green">

          <i class="fas fa-calendar-week"></i>

        </div>

        <h4>
          This Week
        </h4>

        <h2>
          <%= stats?.weeklyLogs || 0 %>
        </h2>

      </div>

      <div class="stat-card red">

        <div class="stat-icon icon-red">

          <i class="fas fa-triangle-exclamation"></i>

        </div>

        <h4>
          Critical Events
        </h4>

        <h2>
          <%= stats?.criticalLogs || 0 %>
        </h2>

      </div>

    </section>

    <!-- FILTERS -->

    <section class="table-toolbar">

      <input
        type="text"
        class="search-box"
        placeholder="Search logs..."
      >

      <div class="toolbar-actions">

        <select>

          <option>
            All Actions
          </option>

          <option>
            LOGIN
          </option>

          <option>
            LOGOUT
          </option>

          <option>
            CREATE_STAFF
          </option>

          <option>
            DELETE_STAFF
          </option>

          <option>
            RESTORE_STAFF
          </option>

          <option>
            CREATE_REQUEST
          </option>

          <option>
            ASSIGN_REQUEST
          </option>

          <option>
            COMPLETE_REQUEST
          </option>

          <option>
            VERIFY_REQUEST
          </option>

        </select>

        <select>

          <option>
            All Roles
          </option>

          <option>
            Admin
          </option>

          <option>
            Staff
          </option>

          <option>
            Resident
          </option>

        </select>

        <select>

          <option>
            Newest First
          </option>

          <option>
            Oldest First
          </option>

        </select>

      </div>

    </section>

    <!-- TABLE -->

    <section class="content-card">

      <div class="table-wrapper">

        <table>

          <thead>

            <tr>

              <th>
                Action
              </th>

              <th>
                User
              </th>

              <th>
                Role
              </th>

              <th>
                IP Address
              </th>

              <th>
                Date
              </th>

              <th>
                Details
              </th>

            </tr>

          </thead>

          <tbody>

            <% if (
              logs &&
              logs.length
            ) { %>

              <% logs.forEach(
                log => {
              %>

                <tr>

                  <td>

                    <%= log.action %>

                  </td>

                  <td>

                    <%= log.userName %>

                  </td>

                  <td>

                    <%= log.role %>

                  </td>

                  <td>

                    <%= log.ipAddress %>

                  </td>

                  <td>

                    <%= new Date(
                      log.createdAt
                    ).toLocaleString()
                    %>

                  </td>

                  <td>

                    <%= log.details %>

                  </td>

                </tr>

              <% }) %>

            <% } else { %>

              <tr>

                <td
                  colspan="6"
                  class="empty-state"
                >

                  <i
                    class="fas fa-shield-halved"
                    style="
                      font-size:42px;
                      margin-bottom:15px;
                    "
                  ></i>

                  <br>

                  No audit logs found.

                </td>

              </tr>

            <% } %>

          </tbody>

        </table>

      </div>

    </section>

    <!-- PAGINATION -->

    <section class="pagination">

      <button
        class="btn btn-outline"
      >

        Previous

      </button>

      <button
        class="btn btn-primary"
      >

        1

      </button>

      <button
        class="btn btn-outline"
      >

        Next

      </button>

    </section>

    <%- include("../partials/dashboard-footer") %>

  </main>

</div>

<script src="/js/dashboard.js"></script>

</body>

</html>