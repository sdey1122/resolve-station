<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Create Staff | ResolveStation</title>

    <!-- Bootstrap -->

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Bootstrap Icons -->

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
    />

    <!-- Dashboard CSS -->

    <link rel="stylesheet" href="/css/admin.css" />
  </head>

  <body>
    <!-- Overlay -->

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <div class="dashboard-wrapper">
      <!-- Sidebar -->

      <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
          <img src="/images/logo/resolvestationlogo.png" alt="ResolveStation" />
        </div>

        <nav class="sidebar-nav">
          <a href="/admin/dashboard" class="nav-link">
            <i class="bi bi-grid"></i>
            <span class="nav-text">Dashboard</span>
          </a>

          <!-- ==========================================
     COMPLAINT MANAGEMENT
========================================== -->

<div class="nav-title">

    Complaint Management

</div>

<a
    href="/admin/complaints/pending"
    class="nav-link"
>

    <i class="bi bi-hourglass-split"></i>

    <span class="nav-text">

        Pending Complaints

    </span>

</a>

<div class="nav-divider"></div>

          <div class="nav-title">Staff Management</div>

          <a href="/admin/staff/show" class="nav-link">
            <i class="bi bi-people"></i>
            <span class="nav-text">View Staff</span>
          </a>

          <a href="/admin/staff/create" class="nav-link active">
            <i class="bi bi-person-plus"></i>
            <span class="nav-text">Manage Staff</span>
          </a>

          <a href="/admin/completed-reviews" class="nav-link">
    <i class="bi bi-patch-check-fill"></i>

    <span>

        Completed Reviews

    </span>
</a>

<a href="/admin/cannot-complete-reviews" class="nav-link">
    <i class="bi bi-exclamation-octagon-fill"></i>

    <span>

        Unable To Complete

    </span>
</a>

          <div class="nav-divider"></div>

          <div class="nav-title">Resident Management</div>

          <a href="/admin/resident/show" class="nav-link">
            <i class="bi bi-house"></i>
            <span class="nav-text">View Residents</span>
          </a>

          <div class="nav-divider"></div>

          <div class="nav-title">System</div>

          <a href="/admin/account-trash" class="nav-link">
            <i class="bi bi-trash"></i>
            <span class="nav-text">Account Trash</span>
          </a>

          <a href="/admin/audit-logs" class="nav-link">
            <i class="bi bi-journal-text"></i>
            <span class="nav-text">Audit Logs</span>
          </a>
        </nav>

        <button class="logout-btn" id="logoutBtn">
          <i class="bi bi-box-arrow-right"></i>

          <span class="logout-text"> Logout </span>
        </button>
      </aside>

      <!-- Main Content -->

      <main class="main-content" id="mainContent">
        <!-- Header -->

        <header class="dashboard-header">
          <div class="header-left">
            <button class="menu-toggle" id="menuToggle">
              <i class="bi bi-list"></i>
            </button>

            <div class="welcome-section">
              <h1>Welcome, <%= user.name %></h1>

              <p>Administrator • <%= user.email %></p>
            </div>
          </div>

          <div class="header-right">
            <button class="notification-btn">
              <i class="bi bi-bell"></i>
            </button>

            <a
  href="/admin/profile"
  class="profile-box"
  title="My Profile"
>
  <img
    src="<%= user.profileImage?.url %>"
    alt="<%= user.name %>"
  />
</a>
        </header>

        <!-- Hero Banner -->

        <section class="hero-banner">
          <div>
            <h2>
              <%= staffId ? "Edit Staff Dashboard" : "Create Staff Dashboard" %>
            </h2>

            <p>
              Manage staff, residents, complaints and system operations from one
              place.
            </p>
          </div>
        </section>

        <!-- Create Staff Card -->

        <section class="staff-form-section">
          <div class="staff-form-card">
            <div class="form-card-header">
  <% if (staffId) { %>
    <h3>Edit Staff Account</h3>

    <p>
      Edit an existing staff member account. Updated login credentials will be sent automatically if the email address is changed.
    </p>
  <% } else { %>
    <h3>Create Staff Account</h3>

    <p>
      Create a new staff member account. Login credentials will be sent automatically.
    </p>
  <% } %>
</div>

            <form id="createStaffForm" enctype="multipart/form-data">
              <input type="hidden" id="staffId" value="<%= staffId || '' %>" />

              <div class="form-grid">
                <!-- Name -->

                <div class="form-group full-width">
                  <label>Full Name *</label>

                  <input
                    type="text"
                    name="name"
                    id="name"
                    placeholder="Enter full name"
                  />

                  <small class="error-message"></small>
                </div>

                <!-- Email -->

                <div class="form-group full-width">
                  <label>Email Address *</label>

                  <input
                    type="email"
                    name="email"
                    id="email"
                    placeholder="Enter email address"
                  />

                  <small class="error-message"></small>
                </div>

                <!-- Upload -->

                <div class="form-group full-width">
                  <label>Profile Image</label>

                  <label class="upload-box">
                    <input
                      type="file"
                      id="profileImage"
                      name="profileImage"
                      accept="image/*"
                      hidden
                    />

                    <div class="upload-content">
                      <i class="bi bi-cloud-arrow-up"></i>

                      <span>Click to Upload Profile Image</span>

                      <small>PNG, JPG, WEBP</small>
                      <span class="image-preview" id="imagePreview"></span>
                    </div>
                  </label>

                  <!-- <div class="image-preview" id="imagePreview"></div> -->
                </div>
              </div>

              <!-- Buttons -->

              <div class="form-actions">
                <button type="button" class="reset-btn" id="resetFormBtn">
                  Reset Form
                </button>

                <button type="submit" class="submit-btn">
                  <%= staffId ? "Update Staff" : "Create Staff" %>
                </button>
              </div>
            </form>
          </div>
        </section>
      </main>
    </div>

    <!-- Logout Modal -->

    <div class="logout-modal" id="logoutModal">
      <div class="logout-modal-card">
        <div class="logout-icon">
          <i class="bi bi-box-arrow-right"></i>
        </div>

        <h3>Logout Confirmation</h3>

        <p>
          Are you sure you want to logout from ResolveStation? You will need to
          sign in again to access your dashboard.
        </p>

        <div class="logout-actions">
          <button class="cancel-btn" id="cancelLogout">Cancel</button>

          <button class="confirm-btn" id="confirmLogout">Yes, Logout</button>
        </div>
      </div>
    </div>

    <!-- Reset Form Modal -->

    <div class="logout-modal" id="resetModal">
      <div class="logout-modal-card">
        <div class="logout-icon">
          <i class="bi bi-arrow-counterclockwise"></i>
        </div>

        <h3>Reset Form</h3>

        <p>
          Are you sure you want to clear all entered information? This action
          cannot be undone.
        </p>

        <div class="logout-actions">
          <button type="button" class="cancel-btn" id="cancelReset">
            Cancel
          </button>

          <button type="button" class="confirm-btn" id="confirmReset">
            Yes, Reset
          </button>
        </div>
      </div>
    </div>

    <div id="successToast" class="success-toast">
      <i class="bi bi-check-circle-fill"></i>

      <div>
        <%= staffId ? "Staff Updated Successfully" : "Staff Created Successfully" %>

        <p>Login credentials have been sent to the registered email.</p>
      </div>
    </div>

    <script src="/js/admin.js"></script>

    <script src="/js/manage-staff.js"></script>
  </body>
</html>
