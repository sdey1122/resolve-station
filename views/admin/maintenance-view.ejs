<!DOCTYPE html>

<html lang="en">

<head>

  <meta charset="UTF-8">

<meta
name="viewport"
content="width=device-width, initial-scale=1.0"

>

  <title>
    Maintenance Details | ResolveStation
  </title>

  <link
    rel="stylesheet"
    href="/css/dashboard.css"
  >

  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
  >

</head>

<body>

<div class="dashboard-container">

<%- include("../partials/admin-sidebar") %>

  <main class="dashboard-main">

<%- include("../partials/dashboard-header") %>

<!-- PAGE HEADER -->

<section class="page-header">

  <div>

    <h1>

      <i class="fas fa-screwdriver-wrench"></i>

      Maintenance Request

    </h1>

    <p>

      Ticket #<%= request.ticketId %>

    </p>

  </div>

  <div class="action-buttons">

    <a
      href="/admin/maintenance"
      class="btn btn-outline"
    >

      <i class="fas fa-arrow-left"></i>

      Back

    </a>

  </div>

</section>

<!-- REQUEST INFO -->

<section class="content-card">

  <h3>

    Request Details

  </h3>

  <div class="table-wrapper">

    <table>

      <tbody>

        <tr>

          <th>
            Title
          </th>

          <td>
            <%= request.title %>
          </td>

        </tr>

        <tr>

          <th>
            Resident
          </th>

          <td>
            <%= request.resident?.name %>
          </td>

        </tr>

        <tr>

          <th>
            Category
          </th>

          <td>
            <%= request.category %>
          </td>

        </tr>

        <tr>

          <th>
            Priority
          </th>

          <td>
            <%= request.priority %>
          </td>

        </tr>

        <tr>

          <th>
            Current Status
          </th>

          <td>
            <%= request.status %>
          </td>

        </tr>

        <tr>

          <th>
            Description
          </th>

          <td>
            <%= request.description %>
          </td>

        </tr>

      </tbody>

    </table>

  </div>

</section>

<!-- ASSIGNMENT -->

<section
  class="content-card"
  style="margin-top:20px;"
>

  <h3>

    Assignment

  </h3>

  <form>

    <div class="form-group">

      <label>

        Assign Staff

      </label>

      <select>

        <option>
          Select Staff
        </option>

        <% staffs.forEach(
          staff => {
        %>

          <option
            value="<%= staff._id %>"
          >

            <%= staff.name %>

          </option>

        <% }) %>

      </select>

    </div>

    <div class="form-group">

      <label>

        Due Date

      </label>

      <input
        type="date"
      >

    </div>

    <div class="form-group">

      <label>

        Estimated Cost

      </label>

      <input
        type="number"
        placeholder="₹"
      >

    </div>

  </form>

</section>

<!-- WORKFLOW -->

<section
  class="content-card"
  style="margin-top:20px;"
>

  <h3>

    Workflow Actions

  </h3>

  <div class="action-buttons">

    <button
      class="btn btn-success"
    >

      <i class="fas fa-check"></i>

      Approve

    </button>

    <button
      class="btn btn-danger"
    >

      <i class="fas fa-xmark"></i>

      Reject

    </button>

    <button
      class="btn btn-primary"
    >

      <i class="fas fa-user-plus"></i>

      Assign Staff

    </button>

    <button
      class="btn btn-outline"
    >

      <i class="fas fa-flag"></i>

      Change Priority

    </button>

  </div>

</section>

<!-- REQUEST IMAGES -->

<section
  class="content-card"
  style="margin-top:20px;"
>

  <h3>

    Attachments

  </h3>

  <div
    style="
      display:flex;
      gap:20px;
      flex-wrap:wrap;
    "
  >

    <% if (
      request.images &&
      request.images.length
    ) { %>

      <% request.images.forEach(
        image => {
      %>

        <img
          src="<%= image.url %>"
          alt="Attachment"
          style="
            width:180px;
            border-radius:16px;
          "
        >

      <% }) %>

    <% } %>

  </div>

</section>

<!-- TIMELINE -->

<section
  class="content-card"
  style="margin-top:20px;"
>

  <h3>

    Timeline

  </h3>

  <div class="table-wrapper">

    <table>

      <thead>

        <tr>

          <th>
            Event
          </th>

          <th>
            User
          </th>

          <th>
            Date
          </th>

        </tr>

      </thead>

      <tbody>

        <% if (
          timeline &&
          timeline.length
        ) { %>

          <% timeline.forEach(
            item => {
          %>

            <tr>

              <td>

                <%= item.action %>

              </td>

              <td>

                <%= item.userName %>

              </td>

              <td>

                <%= new Date(
                  item.createdAt
                ).toLocaleString()
                %>

              </td>

            </tr>

          <% }) %>

        <% } %>

      </tbody>

    </table>

  </div>

</section>

<%- include("../partials/dashboard-footer") %>

  </main>

</div>

<script src="/js/dashboard.js"></script>

</body>
</html>
