<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Administrator Profile | ResolveStation</title>

    <!-- Bootstrap -->

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />

    <!-- Bootstrap Icons -->

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
    />

    <!-- Dashboard -->

    <link rel="stylesheet" href="/css/admin.css" />

    <!-- Profile -->

    <link rel="stylesheet" href="/css/profile.css" />
  </head>

  <body>
    <!-- Sidebar Overlay -->

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <div class="dashboard-wrapper">
      <!-- Sidebar -->

      <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
          <img src="/images/logo/resolvestationlogo.png" alt="ResolveStation" />
        </div>

        <nav class="sidebar-nav">
          <a href="/admin/dashboard" class="nav-link">
            <i class="bi bi-grid"></i>

            <span class="nav-text"> Dashboard </span>
          </a>

          <!-- ==========================================
     COMPLAINT MANAGEMENT
========================================== -->

          <div class="nav-title">Complaint Management</div>

          <a href="/admin/complaints/pending" class="nav-link">
            <i class="bi bi-hourglass-split"></i>

            <span class="nav-text"> Pending Complaints </span>
          </a>

          <div class="nav-divider"></div>

          <div class="nav-title">Staff Management</div>

          <a href="/admin/staff/show" class="nav-link">
            <i class="bi bi-people"></i>

            <span class="nav-text"> View Staff </span>
          </a>

          <a href="/admin/staff/create" class="nav-link">
            <i class="bi bi-person-plus"></i>

            <span class="nav-text"> Manage Staff </span>
          </a>

          <a href="/admin/completed-reviews" class="nav-link">
            <i class="bi bi-patch-check-fill"></i>

            <span> Completed Reviews </span>
          </a>

          <a href="/admin/cannot-complete-reviews" class="nav-link">
            <i class="bi bi-exclamation-octagon-fill"></i>

            <span> Unable To Complete </span>
          </a>

          <div class="nav-divider"></div>

          <div class="nav-title">Resident Management</div>

          <a href="/admin/resident/show" class="nav-link">
            <i class="bi bi-house-door"></i>

            <span class="nav-text"> View Residents </span>
          </a>

          <div class="nav-divider"></div>

          <div class="nav-title">System</div>

          <a href="/admin/account-trash" class="nav-link">
            <i class="bi bi-trash"></i>

            <span class="nav-text"> Account Trash </span>
          </a>

          <a href="/admin/profile" class="nav-link active">
            <i class="bi bi-person-circle"></i>

            <span class="nav-text"> My Profile </span>
          </a>

          <a href="/admin/audit-logs" class="nav-link">
            <i class="bi bi-journal-text"></i>

            <span class="nav-text"> Audit Logs </span>
          </a>
        </nav>

        <button class="logout-btn" id="logoutBtn">
          <i class="bi bi-box-arrow-right"></i>

          <span class="logout-text"> Logout </span>
        </button>
      </aside>

      <!-- Main -->

      <main class="main-content" id="mainContent">
        <!-- Header -->

        <header class="dashboard-header">
          <div class="header-left">
            <button class="menu-toggle" id="menuToggle">
              <i class="bi bi-list"></i>
            </button>

            <div class="welcome-section">
              <h1>Welcome, <%= user.name %></h1>

              <p>Administrator • <%= user.email %></p>
            </div>
          </div>

          <div class="header-right">
            <button class="notification-btn">
              <i class="bi bi-bell"></i>
            </button>

            <a href="/admin/profile" class="profile-box">
              <img
                id="headerProfileImage"
                src="<%= user.profileImage?.url %>"
                alt="<%= user.name %>"
              />
            </a>
          </div>
        </header>
        <!-- ==========================================
             PROFILE HERO
        =========================================== -->

        <section class="profile-hero">
          <!-- Avatar -->

          <div class="hero-avatar">
            <img
              id="profilePreview"
              src="<%= user.profileImage?.url %>"
              alt="<%= user.name %>"
            />

            <label for="profileImage" class="change-avatar">
              <i class="bi bi-camera-fill"></i>
            </label>

            <input id="profileImage" type="file" accept="image/*" hidden />
          </div>

          <!-- Information -->

          <div class="hero-info">
            <span class="hero-role">
              <i class="bi bi-shield-check"></i>

              System Administrator
            </span>

            <h2 id="profileName"><%= user.name %></h2>

            <p class="hero-email" id="profileEmail">
              <i class="bi bi-envelope-fill"></i>

              <%= user.email %>
            </p>

            <div class="hero-meta">
              <div class="hero-meta-card">
                <i class="bi bi-calendar-event"></i>

                <div>
                  <small> Member Since </small>

                  <strong class="memberSince"> -- </strong>
                </div>
              </div>

              <div class="hero-meta-card">
                <i class="bi bi-shield-lock-fill"></i>

                <div>
                  <small> Access Level </small>

                  <strong> Administrator </strong>
                </div>
              </div>
            </div>
          </div>
        </section>
        <!-- ==========================================
             PROFILE CONTENT
        =========================================== -->

        <section class="profile-grid">
          <!-- Biography -->

          <div class="profile-card">
            <div class="card-header">
              <div>
                <h3>Administrator Biography</h3>

                <p>A short introduction about admin</p>
              </div>
            </div>

            <!-- View Mode -->

            <div id="bioView" class="bio-view">
              <p id="bioText">Welcome to ResolveStation.</p>

              <div class="bio-actions">
                <button id="editBiography" class="primary-btn" type="button">
                  <i class="bi bi-pencil-square"></i>

                  Edit Biography
                </button>
              </div>
            </div>

            <!-- Edit Mode -->

            <div id="bioEditor" class="bio-editor" style="display: none">
              <textarea
                id="description"
                maxlength="500"
                placeholder="Tell everyone about yourself..."
              ></textarea>

              <div class="editor-footer">
                <span id="descriptionCounter"> 0 / 500 </span>

                <div>
                  <button
                    id="cancelBiography"
                    class="secondary-btn"
                    type="button"
                  >
                    Cancel
                  </button>

                  <button id="saveBiography" class="primary-btn" type="button">
                    <i class="bi bi-check-lg"></i>

                    Save
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Company -->

          <div class="profile-card">
            <div class="card-header">
              <div>
                <h3>ResolveStation</h3>

                <p>Official organization information.</p>
              </div>
            </div>

            <div class="company-list">
              <div class="company-item">
                <div class="company-icon">
                  <i class="bi bi-geo-alt-fill"></i>
                </div>

                <div>
                  <span>Address</span>

                  <strong> Sector V, Salt Lake, Kolkata </strong>
                </div>
              </div>

              <div class="company-item">
                <div class="company-icon">
                  <i class="bi bi-envelope-fill"></i>
                </div>

                <div>
                  <span>Email</span>

                  <strong> support@resolvestation.com </strong>
                </div>
              </div>

              <div class="company-item">
                <div class="company-icon">
                  <i class="bi bi-globe2"></i>
                </div>

                <div>
                  <span>Website</span>

                  <strong> www.resolvestation.com </strong>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="profile-save-section">
          <button id="saveProfile" class="save-profile-btn">
            <i class="bi bi-floppy-fill"></i>

            Save Profile Changes
          </button>
        </section>
        <!-- ==========================================
             SUCCESS TOAST
        =========================================== -->

        <div id="successToast" class="success-toast">
          <div class="toast-icon">
            <i class="bi bi-check-circle-fill"></i>
          </div>

          <div class="toast-content">
            <h4 id="toastTitle">Success</h4>

            <p id="toastMessage">Profile updated successfully.</p>
          </div>
        </div>
      </main>
    </div>

    <!-- ==========================================
         LOGOUT MODAL
    =========================================== -->

    <div class="logout-modal" id="logoutModal">
      <div class="logout-modal-card">
        <div class="logout-icon">
          <i class="bi bi-box-arrow-right"></i>
        </div>

        <h3>Logout Confirmation</h3>

        <p>
          Are you sure you want to logout from ResolveStation? You will need to
          login again to access your administrator dashboard.
        </p>

        <div class="logout-actions">
          <button class="cancel-btn" id="cancelLogout">Cancel</button>

          <button class="confirm-btn" id="confirmLogout">Yes, Logout</button>
        </div>
      </div>
    </div>

    <!-- Scripts -->

    <script src="/js/admin.js"></script>

    <script src="/js/profile.js"></script>
  </body>
</html>
