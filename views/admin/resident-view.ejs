<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <title>
    Resident Profile | ResolveStation
  </title>

  <link
    rel="stylesheet"
    href="/css/dashboard.css"
  >

  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
  >

</head>

<body>

<div class="dashboard-container">

  <%- include("../partials/admin-sidebar") %>

  <main class="dashboard-main">

    <%- include("../partials/dashboard-header") %>

    <!-- ===================================== -->
    <!-- PAGE HEADER -->
    <!-- ===================================== -->

    <section class="page-header">

      <div>

        <h1>

          <i class="fas fa-user"></i>

          Resident Profile

        </h1>

        <p>

          View resident information and request history.

        </p>

      </div>

      <div class="action-buttons">

        <a
          href="/admin/residents"
          class="btn btn-outline"
        >

          <i class="fas fa-arrow-left"></i>

          Back

        </a>

      </div>

    </section>

    <!-- ===================================== -->
    <!-- PROFILE CARD -->
    <!-- ===================================== -->

    <section class="content-card">

      <div
        style="
          display:flex;
          flex-wrap:wrap;
          gap:30px;
          align-items:center;
        "
      >

        <img
          src="<%= resident.profileImage?.url || '/images/default-avatar.png' %>"
          alt="Resident"
          class="user-avatar"
          style="
            width:120px;
            height:120px;
          "
        >

        <div>

          <h2>

            <%= resident.name %>

          </h2>

          <p>

            <%= resident.email %>

          </p>

          <div
            style="
              margin-top:10px;
              display:flex;
              gap:10px;
              flex-wrap:wrap;
            "
          >

            <% if (
              resident.isVerified
            ) { %>

              <span class="badge badge-active">

                Verified

              </span>

            <% } else { %>

              <span class="badge badge-pending">

                Pending Verification

              </span>

            <% } %>

            <% if (
              resident.isDeleted
            ) { %>

              <span class="badge badge-deleted">

                Deleted

              </span>

            <% } else { %>

              <span class="badge badge-active">

                Active

              </span>

            <% } %>

          </div>

        </div>

      </div>

    </section>

    <!-- ===================================== -->
    <!-- RESIDENT STATS -->
    <!-- ===================================== -->

    <section class="stats-grid">

      <div class="stat-card gold">

        <div class="stat-icon icon-gold">

          <i class="fas fa-list-check"></i>

        </div>

        <h4>
          Total Requests
        </h4>

        <h2>
          <%= stats?.totalRequests || 0 %>
        </h2>

      </div>

      <div class="stat-card blue">

        <div class="stat-icon icon-blue">

          <i class="fas fa-hourglass-half"></i>

        </div>

        <h4>
          Pending
        </h4>

        <h2>
          <%= stats?.pendingRequests || 0 %>
        </h2>

      </div>

      <div class="stat-card green">

        <div class="stat-icon icon-green">

          <i class="fas fa-circle-check"></i>

        </div>

        <h4>
          Completed
        </h4>

        <h2>
          <%= stats?.completedRequests || 0 %>
        </h2>

      </div>

      <div class="stat-card red">

        <div class="stat-icon icon-red">

          <i class="fas fa-ban"></i>

        </div>

        <h4>
          Rejected
        </h4>

        <h2>
          <%= stats?.rejectedRequests || 0 %>
        </h2>

      </div>

    </section>

    <!-- ===================================== -->
    <!-- ACCOUNT INFORMATION -->
    <!-- ===================================== -->

    <section class="content-card">

      <h3>

        Account Information

      </h3>

      <div class="table-wrapper">

        <table>

          <tbody>

            <tr>

              <th>
                Full Name
              </th>

              <td>
                <%= resident.name %>
              </td>

            </tr>

            <tr>

              <th>
                Email
              </th>

              <td>
                <%= resident.email %>
              </td>

            </tr>

            <tr>

              <th>
                Joined
              </th>

              <td>

                <%= new Date(
                  resident.createdAt
                ).toLocaleString() %>

              </td>

            </tr>

            <tr>

              <th>
                Last Login
              </th>

              <td>

                <%= resident.lastLoginAt
                  ? new Date(
                      resident.lastLoginAt
                    ).toLocaleString()
                  : "Never Logged In"
                %>

              </td>

            </tr>

            <tr>

              <th>
                Last Login IP
              </th>

              <td>

                <%= resident.lastLoginIP || "N/A" %>

              </td>

            </tr>

          </tbody>

        </table>

      </div>

    </section>

    <!-- ===================================== -->
    <!-- RECENT REQUESTS -->
    <!-- ===================================== -->

    <section
      class="content-card"
      style="margin-top:20px;"
    >

      <h3>

        Recent Requests

      </h3>

      <div class="table-wrapper">

        <table>

          <thead>

            <tr>

              <th>
                Title
              </th>

              <th>
                Priority
              </th>

              <th>
                Status
              </th>

              <th>
                Assigned Staff
              </th>

              <th>
                Created
              </th>

            </tr>

          </thead>

          <tbody>

            <% if (
              requests &&
              requests.length
            ) { %>

              <% requests.forEach(
                request => {
              %>

                <tr>

                  <td>

                    <%= request.title %>

                  </td>

                  <td>

                    <%= request.priority %>

                  </td>

                  <td>

                    <%= request.status %>

                  </td>

                  <td>

                    <%= request.assignedStaff?.name || "Unassigned" %>

                  </td>

                  <td>

                    <%= new Date(
                      request.createdAt
                    ).toLocaleDateString()
                    %>

                  </td>

                </tr>

              <% }) %>

            <% } else { %>

              <tr>

                <td
                  colspan="5"
                  class="empty-state"
                >

                  No requests found.

                </td>

              </tr>

            <% } %>

          </tbody>

        </table>

      </div>

    </section>

    <!-- ===================================== -->
    <!-- ACTIONS -->
    <!-- ===================================== -->

    <section
      class="action-buttons"
      style="
        margin-top:20px;
        justify-content:flex-end;
      "
    >

      <button
        class="btn btn-danger"
      >

        <i class="fas fa-trash"></i>

        Delete Resident

      </button>

    </section>

    <%- include("../partials/dashboard-footer") %>

  </main>

</div>

<script src="/js/dashboard.js"></script>

</body>
</html>