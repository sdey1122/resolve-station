<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Create Staff | ResolveStation</title>

    <link rel="stylesheet" href="/css/dashboard.css" />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
  </head>

  <body>
    <div class="dashboard-container">
      <%- include("../partials/admin-sidebar") %>

      <main class="dashboard-main">
        <%- include("../partials/dashboard-header") %>

        <!-- ===================================== -->
        <!-- PAGE HEADER -->
        <!-- ===================================== -->

        <section class="page-header">
          <div>
            <h1>
              <i class="fas fa-user-plus"></i>

              Create Staff
            </h1>

            <p>Create a new staff account for ResolveStation.</p>
          </div>

          <a href="/admin/staff" class="btn btn-outline">
            <i class="fas fa-arrow-left"></i>

            Back To Staff
          </a>
        </section>

        <!-- ===================================== -->
        <!-- CREATE STAFF FORM -->
        <!-- ===================================== -->

        <section class="content-card">
          <form
            action="/api/admin/staff"
            method="POST"
            enctype="multipart/form-data"
          >
            <!-- PROFILE IMAGE -->

            <div class="form-group">
              <label> Profile Image </label>

              <input type="file" name="profileImage" accept="image/*" />
            </div>

            <!-- FULL NAME -->

            <div class="form-group">
              <label> Full Name </label>

              <input
                type="text"
                name="name"
                placeholder="Enter full name"
                required
              />
            </div>

            <!-- EMAIL -->

            <div class="form-group">
              <label> Email Address </label>

              <input
                type="email"
                name="email"
                placeholder="Enter email address"
                required
              />
            </div>

            <!-- INFO BOX -->

            <div class="content-card">
              <h3>Staff Account Information</h3>

              <p>
                A temporary password will be generated automatically and sent to
                the staff member's email address.
              </p>
            </div>

            <!-- BUTTONS -->

            <div class="action-buttons">
              <button type="submit" class="btn btn-primary">
                <i class="fas fa-user-plus"></i>

                Create Staff
              </button>

              <a href="/admin/staff" class="btn btn-outline"> Cancel </a>
            </div>
          </form>
        </section>

        <%- include("../partials/dashboard-footer") %>
      </main>
    </div>

    <script src="/js/dashboard.js"></script>
  </body>
</html>
