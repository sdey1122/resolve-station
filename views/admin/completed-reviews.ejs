<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>

        Completed Reviews | ResolveStation

    </title>

    <!-- Bootstrap -->

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

    <!-- Bootstrap Icons -->

    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
    >

    <!-- CSS -->

    <link
        rel="stylesheet"
        href="/css/admin.css"
    >

    <link
        rel="stylesheet"
        href="/css/completed-reviews.css"
    >

</head>

<body>

<div
    class="sidebar-overlay"
    id="sidebarOverlay"
></div>

<div class="dashboard-wrapper">

    <!-- ==========================================
         SIDEBAR
    ========================================== -->

    <aside
        class="sidebar"
        id="sidebar"
    >

        <div class="sidebar-header">

            <img
                src="/images/logo/resolvestationlogo.png"
                alt="ResolveStation"
            >

        </div>

        <nav class="sidebar-nav">

            <a
                href="/admin/dashboard"
                class="nav-link"
            >

                <i class="bi bi-grid"></i>

                <span class="nav-text">

                    Dashboard

                </span>

            </a>

            <div class="nav-title">

                Complaint Management

            </div>

            <a
                href="/admin/complaints/pending"
                class="nav-link"
            >

                <i class="bi bi-hourglass-split"></i>

                <span class="nav-text">

                    Pending Complaints

                </span>

            </a>

            <a
                href="/admin/completed-reviews"
                class="nav-link active"
            >

                <i class="bi bi-patch-check-fill"></i>

                <span class="nav-text">

                    Completed Reviews

                </span>

            </a>

            <a
                href="/admin/cannot-complete-reviews"
                class="nav-link"
            >

                <i class="bi bi-exclamation-octagon-fill"></i>

                <span class="nav-text">

                    Unable To Complete

                </span>

            </a>

            <div class="nav-divider"></div>

            <div class="nav-title">

                Staff Management

            </div>

            <a
                href="/admin/staff/show"
                class="nav-link"
            >

                <i class="bi bi-people"></i>

                <span class="nav-text">

                    View Staff

                </span>

            </a>

            <a
                href="/admin/staff/create"
                class="nav-link"
            >

                <i class="bi bi-person-plus"></i>

                <span class="nav-text">

                    Manage Staff

                </span>

            </a>

            <div class="nav-divider"></div>

            <div class="nav-title">

                Resident Management

            </div>

            <a
                href="/admin/resident/show"
                class="nav-link"
            >

                <i class="bi bi-house"></i>

                <span class="nav-text">

                    View Residents

                </span>

            </a>

            <div class="nav-divider"></div>

            <div class="nav-title">

                System

            </div>

            <a
                href="/admin/account-trash"
                class="nav-link"
            >

                <i class="bi bi-trash"></i>

                <span class="nav-text">

                    Account Trash

                </span>

            </a>

            <a
                href="/admin/audit-logs"
                class="nav-link"
            >

                <i class="bi bi-journal-text"></i>

                <span class="nav-text">

                    Audit Logs

                </span>

            </a>

        </nav>

        <button
            class="logout-btn"
            id="logoutBtn"
        >

            <i class="bi bi-box-arrow-right"></i>

            <span class="logout-text">

                Logout

            </span>

        </button>

    </aside>

    <!-- ==========================================
         MAIN
    ========================================== -->

    <main
        class="main-content"
        id="mainContent"
    >

        <header class="dashboard-header">

            <div class="header-left">

                <button
                    class="menu-toggle"
                    id="menuToggle"
                >

                    <i class="bi bi-list"></i>

                </button>

                <div class="welcome-section">

                    <h1>

                        Welcome,

                        <%= user.name %>

                    </h1>

                    <p>

                        Administrator • <%= user.email %>

                    </p>

                </div>

            </div>

            <div class="header-right">

                <button class="notification-btn">

                    <i class="bi bi-bell"></i>

                </button>

                <a
                    href="/admin/profile"
                    class="profile-box"
                >

                    <img
                        src="<%= user.profileImage?.url %>"
                        alt="<%= user.name %>"
                    >

                </a>

            </div>

        </header>

        <!-- ==========================================
             HERO
        ========================================== -->

        <section class="hero-banner complaint-hero">

            <div class="hero-content">

                <span class="hero-tag">

                    Staff Completion Review

                </span>

                <h2>

                    Completed Maintenance Reviews

                </h2>

                <p>

                    Verify maintenance proof submitted by staff,
                    review completion images, validate pricing,
                    and approve or reject completed maintenance requests.

                </p>

            </div>

        </section>

        <!-- ==========================================
             STATS
        ========================================== -->

        <section class="stats-grid">

            <div class="stat-card">

                <i class="bi bi-patch-check-fill"></i>

                <h3>

                    <%= stats.pendingReview %>

                </h3>

                <span>

                    Pending Review

                </span>

            </div>

            <div class="stat-card">

                <i class="bi bi-check-circle-fill"></i>

                <h3>

                    <%= stats.approvedToday %>

                </h3>

                <span>

                    Approved Today

                </span>

            </div>

            <div class="stat-card">

                <i class="bi bi-x-circle-fill"></i>

                <h3>

                    <%= stats.rejectedToday %>

                </h3>

                <span>

                    Rejected Today

                </span>

            </div>

            <div class="stat-card">

                <i class="bi bi-cash-stack"></i>

                <h3>

                    ₹<%= stats.totalValue %>

                </h3>

                <span>

                    Total Work Value

                </span>

            </div>

        </section>

        <!-- ==========================================
     SEARCH & FILTER
========================================== -->

<section class="complaint-toolbar">

    <div class="search-box">

        <i class="bi bi-search"></i>

        <input
            type="text"
            id="searchReview"
            placeholder="Search complaint number, resident, staff..."
        >

    </div>

    <select id="categoryFilter">

        <option value="">

            All Categories

        </option>

        <option value="Electrical">Electrical</option>

        <option value="Plumbing">Plumbing</option>

        <option value="Cleaning">Cleaning</option>

        <option value="Water">Water</option>

        <option value="Internet">Internet</option>

        <option value="Lift">Lift</option>

        <option value="Parking">Parking</option>

        <option value="Security">Security</option>

        <option value="Garden">Garden</option>

        <option value="Other">Other</option>

    </select>

</section>

<!-- ==========================================
     REVIEW GRID
========================================== -->

<section class="complaint-grid">

<% if (!complaints || complaints.length === 0) { %>

<div class="empty-state">

    <img
        src="/images/empty-complaints.svg"
        alt="No Reviews"
    >

    <h3>

        Nothing To Review

    </h3>

    <p>

        Staff completed maintenance requests will appear here
        for administrator verification.

    </p>

</div>

<% } else { %>

<% complaints.forEach((complaint)=>{ %>

<article class="ticket-card review-card">

    <!-- ======================================
         HEADER
    ======================================= -->

    <div class="ticket-header">

        <span class="ticket-status success">

            Waiting Review

        </span>

        <span class="ticket-number">

            #<%= complaint.complaintNumber %>

        </span>

    </div>

    <!-- ======================================
         TITLE
    ======================================= -->

    <h3 class="ticket-title">

        <%= complaint.title %>

    </h3>

    <p class="ticket-description">

        <%= complaint.description.length > 90
            ? complaint.description.substring(0,90) + "..."
            : complaint.description %>

    </p>

    <!-- ======================================
         BEFORE / AFTER IMAGES
    ======================================= -->

    <div class="review-images">

        <div class="review-image">

            <small>

                Complaint Image

            </small>

            <img
                src="<%= complaint.image?.url || '/images/no-image.png' %>"
                alt=""
            >

        </div>

        <div class="review-image">

            <small>

                Completion Proof

            </small>

            <img
                src="<%= complaint.completionImage?.url || '/images/no-image.png' %>"
                alt=""
            >

        </div>

    </div>

    <!-- ======================================
         RESIDENT
    ======================================= -->

    <div class="ticket-row">

        <i class="bi bi-house-fill"></i>

        <span>

            <strong>

                <%= complaint.resident?.name %>

            </strong>

        </span>

    </div>

    <!-- ======================================
         STAFF
    ======================================= -->

    <div class="ticket-row">

        <i class="bi bi-person-workspace"></i>

        <span>

            <strong>

                <%= complaint.assignedStaff?.name %>

            </strong>

        </span>

    </div>

    <!-- ======================================
         CATEGORY
    ======================================= -->

    <div class="ticket-row">

        <i class="bi bi-tag-fill"></i>

        <span>

            <%= complaint.category %>

        </span>

    </div>

    <!-- ======================================
         COMPLETION DATE
    ======================================= -->

    <div class="ticket-row">

        <i class="bi bi-calendar-check-fill"></i>

        <span>

            <%= complaint.completedAt
                ? new Date(complaint.completedAt).toLocaleDateString("en-IN")
                : "-" %>

        </span>

    </div>

    <!-- ==========================================
     PRICE SUMMARY
========================================== -->

<div class="price-summary">

    <div class="price-item">

        <small>

            Original Price

        </small>

        <strong class="price-original">

            ₹<%= complaint.estimatedPrice %>

        </strong>

    </div>

    <div class="price-arrow">

        <i class="bi bi-arrow-right"></i>

    </div>

    <div class="price-item">

        <small>

            Final Price

        </small>

        <strong class="price-final">

            ₹<%= complaint.finalPrice %>

        </strong>

    </div>

</div>

<div class="deduction-badge">

    <i class="bi bi-percent"></i>

    <span>

        <%= complaint.deductionPercent %>% Deducted

    </span>

</div>

<!-- ==========================================
     STAFF INFORMATION
========================================== -->

<div class="review-user">

    <img
        src="<%= complaint.assignedStaff?.profileImage?.url || '/images/default-avatar.png' %>"
        alt=""
    >

    <div>

        <small>

            Maintenance Staff

        </small>

        <strong>

            <%= complaint.assignedStaff?.name %>

        </strong>

    </div>

</div>

<!-- ==========================================
     RESIDENT INFORMATION
========================================== -->

<div class="review-user">

    <img
        src="<%= complaint.resident?.profileImage?.url || '/images/default-avatar.png' %>"
        alt=""
    >

    <div>

        <small>

            Resident

        </small>

        <strong>

            <%= complaint.resident?.name %>

        </strong>

    </div>

</div>

<!-- ==========================================
     STAFF REMARK
========================================== -->

<div class="remark-box">

    <strong>

        Staff Remark

    </strong>

    <p>

        <%= complaint.completionRemark || "Maintenance completed successfully." %>

    </p>

</div>

<!-- ==========================================
     TIMELINE
========================================== -->

<div class="timeline-card">

    <div class="timeline-item">

        <i class="bi bi-calendar-plus"></i>

        <div>

            <small>

                Complaint Submitted

            </small>

            <strong>

                <%= new Date(complaint.createdAt).toLocaleString("en-IN") %>

            </strong>

        </div>

    </div>

    <div class="timeline-item">

        <i class="bi bi-check2-circle"></i>

        <div>

            <small>

                Maintenance Completed

            </small>

            <strong>

                <%= complaint.completedAt
                    ? new Date(complaint.completedAt).toLocaleString("en-IN")
                    : "-" %>

            </strong>

        </div>

    </div>

</div>

<!-- ==========================================
     ACTIONS
========================================== -->

<div class="review-actions">

    <button
        class="approve-btn"
        data-id="<%= complaint._id %>"
    >

        <i class="bi bi-check-circle-fill"></i>

        Approve & Close

    </button>

    <button
        class="reject-btn"
        data-id="<%= complaint._id %>"
    >

        <i class="bi bi-arrow-counterclockwise"></i>

        Return To Staff

    </button>

</div>

</article>

<% }) %>

<% } %>

</section>

<!-- ==========================================
     PAGINATION
========================================== -->

<% if (pagination && pagination.totalPages > 1) { %>

<section class="pagination-wrapper">

    <div class="pagination">

        <% if (pagination.hasPrevPage) { %>

        <a
            href="?page=<%= pagination.currentPage-1 %>"
            class="page-btn"
        >

            <i class="bi bi-chevron-left"></i>

        </a>

        <% } %>

        <% for(let page=1;page<=pagination.totalPages;page++){ %>

        <a
            href="?page=<%= page %>"
            class="page-btn <%= page===pagination.currentPage ? 'active':'' %>"
        >

            <%= page %>

        </a>

        <% } %>

        <% if (pagination.hasNextPage) { %>

        <a
            href="?page=<%= pagination.currentPage+1 %>"
            class="page-btn"
        >

            <i class="bi bi-chevron-right"></i>

        </a>

        <% } %>

    </div>

</section>

<% } %>

<!-- ==========================================
     LOGOUT MODAL
========================================== -->

<div
    class="logout-modal"
    id="logoutModal"
>

    <div class="logout-modal-card">

        <div class="logout-icon">

            <i class="bi bi-box-arrow-right"></i>

        </div>

        <h3>

            Logout Confirmation

        </h3>

        <p>

            Are you sure you want to logout from
            <strong>ResolveStation</strong>?

        </p>

        <div class="logout-actions">

            <button
                class="cancel-btn"
                id="cancelLogout"
            >

                Cancel

            </button>

            <button
                class="confirm-btn"
                id="confirmLogout"
            >

                Logout

            </button>

        </div>

    </div>

</div>

<!-- ==========================================
     APPROVE MODAL
========================================== -->

<div
    class="modal fade"
    id="approveModal"
    tabindex="-1"
>

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">

                    Approve Maintenance

                </h5>

                <button
                    class="btn-close"
                    data-bs-dismiss="modal"
                ></button>

            </div>

            <div class="modal-body">

                <p>

                    The complaint will be permanently closed.

                </p>

                <p class="mb-0">

                    The resident will immediately see the completed maintenance.

                </p>

            </div>

            <div class="modal-footer">

                <button
                    class="btn btn-light"
                    data-bs-dismiss="modal"
                >

                    Cancel

                </button>

                <button
                    class="btn btn-success"
                    id="approveSubmitBtn"
                >

                    <i class="bi bi-check-circle-fill"></i>

                    Approve

                </button>

            </div>

        </div>

    </div>

</div>

<!-- ==========================================
     REJECT MODAL
========================================== -->

<div
    class="modal fade"
    id="rejectModal"
    tabindex="-1"
>

    <div class="modal-dialog modal-dialog-centered">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">

                    Return To Staff

                </h5>

                <button
                    class="btn-close"
                    data-bs-dismiss="modal"
                ></button>

            </div>

            <div class="modal-body">

                <label class="form-label">

                    Administrator Remark

                </label>

                <textarea
                    id="rejectReason"
                    class="form-control"
                    rows="5"
                    placeholder="Explain what needs to be corrected..."
                ></textarea>

            </div>

            <div class="modal-footer">

                <button
                    class="btn btn-light"
                    data-bs-dismiss="modal"
                >

                    Cancel

                </button>

                <button
                    class="btn btn-danger"
                    id="rejectSubmitBtn"
                >

                    <i class="bi bi-arrow-counterclockwise"></i>

                    Send Back

                </button>

            </div>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

<script src="/js/toast.js"></script>

<script src="/js/admin.js"></script>

<script src="/js/completed-reviews.js"></script>

</body>

</html>