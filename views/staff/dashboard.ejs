<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>

        Staff Dashboard | ResolveStation

    </title>

    <!-- Shared Dashboard -->

    <link
        rel="stylesheet"
        href="/css/resident.css"
    >

    <!-- Staff Dashboard -->

    <link
        rel="stylesheet"
        href="/css/staff.css"
    >

    <!-- Bootstrap Icons -->

    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    >

</head>

<body>

<div
    class="sidebar-overlay"
    id="sidebarOverlay"
></div>

<div class="dashboard-wrapper">

    <!-- =======================================
         SIDEBAR
    ======================================== -->

    <aside
        class="sidebar"
        id="sidebar"
    >

        <div class="sidebar-logo">

            <a href="/staff/dashboard">

                <img
                    src="/images/logo/resolvestationlogo.svg"
                    alt="ResolveStation"
                >

            </a>

        </div>

        <nav class="sidebar-menu">

            <a
                href="/staff/dashboard"
                class="sidebar-link active"
            >

                <i class="bi bi-grid-fill"></i>

                <span>

                    Dashboard

                </span>

            </a>

            <a
                href="/staff/profile"
                class="sidebar-link"
            >

                <i class="bi bi-person-circle"></i>

                <span>

                    My Profile

                </span>

            </a>

        </nav>

        <div class="sidebar-footer">

            <button
                id="logoutBtn"
                class="sidebar-link logout-btn"
                type="button"
            >

                <i class="bi bi-box-arrow-right"></i>

                <span>

                    Logout

                </span>

            </button>

        </div>

    </aside>

    <!-- =======================================
         MAIN CONTENT
    ======================================== -->

    <main
        class="main-content"
        id="mainContent"
    >

        <header class="dashboard-header">

            <div class="header-left">

                <button
                    id="menuToggle"
                    class="menu-toggle"
                >

                    <i class="bi bi-list"></i>

                </button>

                <div class="header-title">

                    <h1>

                        Welcome Back,

                        <span>

                            <%= user.name %>

                        </span>

                    </h1>

                    <p>

                        <i class="bi bi-envelope-fill"></i>

                        <%= user.email %>

                    </p>

                </div>

            </div>

            <div class="header-right">

                <button class="notification-btn">

                    <i class="bi bi-bell-fill"></i>

                    <span class="notification-dot"></span>

                </button>

                <a
                    href="/staff/profile"
                    class="header-profile"
                >

                    <img
                        src="<%= user.profileImage?.url || '/images/default-avatar.png' %>"
                        alt="<%= user.name %>"
                    >

                </a>

            </div>

        </header>

        <div class="dashboard-content">

                  <!-- ==========================================
             HERO
        ========================================== -->

        <section class="staff-hero">

            <div class="hero-content">

                <span class="hero-badge">

                    <i class="bi bi-tools"></i>

                    STAFF WORKSPACE

                </span>

                <h2>

                    Ready for Today's Assignments?

                </h2>

                <p>

                    Complete maintenance jobs before their deadlines, upload proof after successful completion, or report issues that prevent completion. Every update is sent directly to the administrator for review.

                </p>

                <div class="hero-actions">

                    <a
                        href="/staff/profile"
                        class="hero-btn hero-primary hb-stf"
                    >

                        <i class="bi bi-person-circle"></i>

                        My Profile

                    </a>

                </div>

            </div>

            <div class="hero-image">

                <img
                    src="/images/logo/resolvestationlogo.svg"
                    alt="Staff Dashboard"
                >

            </div>

        </section>

        <!-- ==========================================
             DASHBOARD STATS
        ========================================== -->

        <section class="dashboard-stats">

            <div class="stat-card">

                <div class="stat-icon total">

                    <i class="bi bi-list-task"></i>

                </div>

                <div class="stat-info">

                    <span>

                        Assigned Jobs

                    </span>

                    <h3>

                        <%= stats.assigned || 0 %>

                    </h3>

                </div>

            </div>

            <div class="stat-card">

                <div class="stat-icon completed">

                    <i class="bi bi-check-circle-fill"></i>

                </div>

                <div class="stat-info">

                    <span>

                        Completed

                    </span>

                    <h3>

                        <%= stats.completed || 0 %>

                    </h3>

                </div>

            </div>

            <div class="stat-card">

                <div class="stat-icon pending">

                    <i class="bi bi-hourglass-split"></i>

                </div>

                <div class="stat-info">

                    <span>

                        Pending Review

                    </span>

                    <h3>

                        <%= stats.pendingReview || 0 %>

                    </h3>

                </div>

            </div>

            <div class="stat-card">

                <div class="stat-icon assigned">

                    <i class="bi bi-alarm-fill"></i>

                </div>

                <div class="stat-info">

                    <span>

                        Overdue

                    </span>

                    <h3>

                        <%= stats.overdue || 0 %>

                    </h3>

                </div>

            </div>

        </section>

        <!-- ==========================================
             SECTION HEADER
        ========================================== -->

        <div class="section-header">

            <div>

                <span class="section-badge">

                    Active Jobs

                </span>

                <h2>

                    Assigned Maintenance Tasks

                </h2>

                <p>

                    Complete every task before its deadline and keep residents satisfied.

                </p>

            </div>

        </div>

        <!-- ==========================================
     TASK GRID
========================================== -->

<% if (assignedJobs.length) { %>

<div class="complaint-grid">

    <% assignedJobs.forEach((job)=>{ %>

    <div class="complaint-card">

        <!-- ======================================
             IMAGE
        ======================================= -->

        <div class="complaint-image">

            <img
                src="<%= job.image?.url || '/images/no-image.png' %>"
                alt="<%= job.title %>"
            >

            <div class="image-overlay image-assigned"></div>

            <span class="status-badge status-assigned">

                Assigned

            </span>

            <span class="priority-badge priority-normal">

                Active

            </span>

        </div>

        <!-- ======================================
             BODY
        ======================================= -->

        <div class="complaint-body">

            <div class="complaint-top">

                <span class="complaint-number">

                    #<%= job.complaintNumber %>

                </span>

                <span class="complaint-category">

                    <%= job.category %>

                </span>

            </div>

            <h3>

                <%= job.title %>

            </h3>

            <p class="complaint-description">

                <%= job.description %>

            </p>

            <!-- Countdown -->

            <div
                class="countdown-box"
                data-deadline="<%= job.deadlineAt %>"
            >

                <i class="bi bi-clock-history"></i>

                <span class="countdown-text">

                    Loading...

                </span>

            </div>

            <!-- Resident -->

            <div class="assigned-staff">

                <div class="staff-left">

                    <i class="bi bi-person-fill"></i>

                    <div>

                        <small>

                            Resident

                        </small>

                        <strong>

                            <%= job.resident?.name %>

                        </strong>

                    </div>

                </div>

            </div>

            <!-- Price -->

           <div class="price-box">

    <span>Estimated Cost</span>

    <strong data-price="<%= job.estimatedPrice %>">

        ₹<%= job.estimatedPrice %>

    </strong>

</div>

            <!-- Footer -->

            <div class="complaint-footer">

                <span>

                    Assigned

                    <%= new Date(job.createdAt).toLocaleDateString() %>

                </span>

                <span class="complaint-id">

                    <%= job.status %>

                </span>

            </div>

            <!-- ======================================
                 ACTIONS
            ======================================= -->

            <div class="task-actions">

                <button
                    class="task-complete-btn"
                    data-id="<%= job._id %>"
                >

                    <i class="bi bi-check-circle-fill"></i>

                    Job Completed

                </button>

                <button
                    class="task-failed-btn"
                    data-id="<%= job._id %>"
                >

                    <i class="bi bi-x-circle-fill"></i>

                    Unable To Complete

                </button>

            </div>

        </div>

    </div>

    <% }) %>

</div>

<% } else { %>

<div class="empty-complaints">

    <img
        src="/images/empty-task.svg"
        alt="No Tasks"
    >

    <h3>

        You're All Caught Up!

    </h3>

    <p>

        There are currently no maintenance jobs assigned to you.
        New assignments will automatically appear here once the administrator assigns them.

    </p>

</div>

<% } %>

        </div>

    </main>

</div>

<!-- ==========================================
     LOGOUT MODAL
========================================== -->

<div
    class="logout-modal"
    id="logoutModal"
>

    <div class="logout-modal-card">

        <div class="logout-icon">

            <i class="bi bi-box-arrow-right"></i>

        </div>

        <h2>

            Logout?

        </h2>

        <p>

            Are you sure you want to logout from your
            <strong>Staff Account</strong>?

        </p>

        <div class="logout-actions">

            <button
                id="cancelLogout"
                class="btn-cancel"
                type="button"
            >

                Cancel

            </button>

            <button
                id="confirmLogout"
                class="btn-confirm"
                type="button"
            >

                Logout

            </button>

        </div>

    </div>

</div>

<!-- ==========================================
     COMPLETE JOB MODAL
========================================== -->

<div
    class="logout-modal"
    id="completeJobModal"
>

    <div class="logout-modal-card staff-modal">

        <div class="logout-icon">

            <i class="bi bi-check-circle-fill"></i>

        </div>

        <h2>

            Complete Maintenance Job

        </h2>

        <p>

            Upload a clear proof image after successfully completing the assigned maintenance work.

        </p>

        <form
            id="completeJobForm"
            enctype="multipart/form-data"
        >

            <input
                type="hidden"
                id="completeComplaintId"
            >

            <input
                type="file"
                id="completionImage"
                accept="image/*"
                required
            >

            <button
                type="submit"
                class="btn-confirm full-btn btn-stf-cf"
            >
                Submit Completion

            </button>

        </form>

    </div>

</div>

<!-- ==========================================
     CANNOT COMPLETE MODAL
========================================== -->

<div
    class="logout-modal"
    id="cannotCompleteModal"
>

    <div class="logout-modal-card staff-modal">

        <div class="logout-icon">

            <i class="bi bi-exclamation-triangle-fill"></i>

        </div>

        <h2>

            Unable To Complete

        </h2>

        <p>

            Explain why the maintenance work could not be completed.
            The administrator will review your report.

        </p>

        <form id="cannotCompleteForm">

            <input
                type="hidden"
                id="cannotComplaintId"
            >

            <textarea
                id="staffRemark"
                rows="6"
                placeholder="Write the reason..."
                required
            ></textarea>

            <button
                type="submit"
                class="btn-confirm full-btn sbt-stf-cn"
            >

                Submit Report

            </button>

        </form>

    </div>

</div>

<!-- ==========================================
     STAFF DATA
========================================== -->

<script>

window.STAFF={

    id:"<%= user._id %>",

    name:"<%= user.name %>",

    email:"<%= user.email %>"

};

</script>

<!-- Toast -->

<script src="/js/toast.js"></script>

<!-- Staff -->

<script src="/js/staff.js"></script>

</body>

</html>