<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <title>
    Assigned Jobs | ResolveStation
  </title>

  <link
    rel="stylesheet"
    href="/css/dashboard.css"
  >

  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
  >

</head>

<body>

<div class="dashboard-container">

  <%- include("../partials/staff-sidebar") %>

  <main class="dashboard-main">

    <%- include("../partials/dashboard-header") %>

    <!-- ===================================== -->
    <!-- PAGE HEADER -->
    <!-- ===================================== -->

    <section class="page-header">

      <div>

        <h1>

          <i class="fas fa-list-check"></i>

          Assigned Jobs

        </h1>

        <p>

          View and manage your assigned maintenance requests.

        </p>

      </div>

    </section>

    <!-- ===================================== -->
    <!-- STATS -->
    <!-- ===================================== -->

    <section class="stats-grid">

      <div class="stat-card blue">

        <div class="stat-icon icon-blue">

          <i class="fas fa-list-check"></i>

        </div>

        <h4>
          Total Assigned
        </h4>

        <h2>
          <%= stats?.assigned || 0 %>
        </h2>

      </div>

      <div class="stat-card orange">

        <div class="stat-icon icon-orange">

          <i class="fas fa-spinner"></i>

        </div>

        <h4>
          In Progress
        </h4>

        <h2>
          <%= stats?.inProgress || 0 %>
        </h2>

      </div>

      <div class="stat-card green">

        <div class="stat-icon icon-green">

          <i class="fas fa-circle-check"></i>

        </div>

        <h4>
          Completed
        </h4>

        <h2>
          <%= stats?.completed || 0 %>
        </h2>

      </div>

      <div class="stat-card red">

        <div class="stat-icon icon-red">

          <i class="fas fa-clock"></i>

        </div>

        <h4>
          Overdue
        </h4>

        <h2>
          <%= stats?.overdue || 0 %>
        </h2>

      </div>

    </section>

    <!-- ===================================== -->
    <!-- FILTERS -->
    <!-- ===================================== -->

    <section class="table-toolbar">

      <input
        type="text"
        class="search-box"
        placeholder="Search jobs..."
      >

      <div class="toolbar-actions">

        <select>

          <option>
            All Priorities
          </option>

          <option>
            Low
          </option>

          <option>
            Medium
          </option>

          <option>
            High
          </option>

          <option>
            Critical
          </option>

        </select>

        <select>

          <option>
            All Status
          </option>

          <option>
            Assigned
          </option>

          <option>
            In Progress
          </option>

          <option>
            Completed
          </option>

          <option>
            Overdue
          </option>

        </select>

      </div>

    </section>

    <!-- ===================================== -->
    <!-- TABLE -->
    <!-- ===================================== -->

    <section class="content-card">

      <div class="table-wrapper">

        <table>

          <thead>

            <tr>

              <th>
                Ticket ID
              </th>

              <th>
                Title
              </th>

              <th>
                Resident
                              <th>
                Priority
              </th>

              <th>
                Status
              </th>

              <th>
                Due Date
              </th>

              <th>
                Actions
              </th>

            </tr>

          </thead>

          <tbody>

            <% if (
              jobs &&
              jobs.length
            ) { %>

              <% jobs.forEach(
                job => {
              %>

                <tr>

                  <td>

                    #<%= job.ticketId %>

                  </td>

                  <td>

                    <%= job.title %>

                  </td>

                  <td>

                    <%= job.resident?.name || "N/A" %>

                  </td>

                  <td>

                    <% if (
                      job.priority ===
                      "LOW"
                    ) { %>

                      <span class="badge badge-info">

                        Low

                      </span>

                    <% } else if (
                      job.priority ===
                      "MEDIUM"
                    ) { %>

                      <span class="badge badge-warning">

                        Medium

                      </span>

                    <% } else if (
                      job.priority ===
                      "HIGH"
                    ) { %>

                      <span class="badge badge-danger">

                        High

                      </span>

                    <% } else { %>

                      <span class="badge badge-critical">

                        Critical

                      </span>

                    <% } %>

                  </td>

                  <td>

                    <% if (
                      job.status ===
                      "ASSIGNED"
                    ) { %>

                      <span class="badge badge-primary">

                        Assigned

                      </span>

                    <% } else if (
                      job.status ===
                      "IN_PROGRESS"
                    ) { %>

                      <span class="badge badge-warning">

                        In Progress

                      </span>

                    <% } else if (
                      job.status ===
                      "COMPLETED"
                    ) { %>

                      <span class="badge badge-success">

                        Completed

                      </span>

                    <% } else { %>

                      <span class="badge badge-danger">

                        Overdue

                      </span>

                    <% } %>

                  </td>

                  <td>

                    <%= job.dueDate
                      ? new Date(
                          job.dueDate
                        ).toLocaleDateString()
                      : "-"
                    %>

                  </td>

                  <td>

                    <div class="action-buttons">

                      <a
                        href="/staff/jobs/<%= job._id %>"
                        class="btn btn-sm btn-outline"
                      >

                        <i class="fas fa-eye"></i>

                      </a>

                      <% if (
                        job.status ===
                        "ASSIGNED"
                      ) { %>

                        <button
                          class="btn btn-sm btn-primary"
                        >

                          <i class="fas fa-play"></i>

                        </button>

                      <% } %>

                      <% if (
                        job.status ===
                        "IN_PROGRESS"
                      ) { %>

                        <button
                          class="btn btn-sm btn-success"
                        >

                          <i class="fas fa-check"></i>

                        </button>

                      <% } %>

                    </div>

                  </td>

                </tr>

              <% }) %>

            <% } else { %>

              <tr>

                <td
                  colspan="7"
                  class="empty-state"
                >

                  <i
                    class="fas fa-clipboard-list"
                    style="
                      font-size:42px;
                      margin-bottom:15px;
                    "
                  ></i>

                  <br>

                  No assigned jobs found.

                </td>

              </tr>

            <% } %>

          </tbody>

        </table>

      </div>

    </section>

    <!-- ===================================== -->
    <!-- PAGINATION -->
    <!-- ===================================== -->

    <section class="pagination">

      <button
        class="btn btn-outline"
      >

        Previous

      </button>

      <button
        class="btn btn-primary"
      >

        1

      </button>

      <button
        class="btn btn-outline"
      >

        Next

      </button>

    </section>

    <%- include("../partials/dashboard-footer") %>

  </main>

</div>

<script src="/js/dashboard.js"></script>

</body>

</html>