<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8">

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  >

  <title>
    Complaints | ResolveStation
  </title>

  <link
    rel="stylesheet"
    href="/css/dashboard.css"
  >

  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
  >

</head>

<body>

<div class="dashboard-container">

  <%- include("../partials/resident-sidebar") %>

  <main class="dashboard-main">

    <%- include("../partials/dashboard-header") %>

    <!-- ===================================== -->
    <!-- PAGE HEADER -->
    <!-- ===================================== -->

    <section class="page-header">

      <div>

        <h1>

          <i class="fas fa-triangle-exclamation"></i>

          My Complaints

        </h1>

        <p>

          Track and manage submitted complaints.

        </p>

      </div>

      <button
        class="btn btn-primary"
      >

        <i class="fas fa-plus"></i>

        New Complaint

      </button>

    </section>

    <!-- ===================================== -->
    <!-- STATS -->
    <!-- ===================================== -->

    <section class="stats-grid">

      <div class="stat-card blue">

        <h4>
          Total Complaints
        </h4>

        <h2>
          <%= stats?.total || 0 %>
        </h2>

      </div>

      <div class="stat-card orange">

        <h4>
          Pending
        </h4>

        <h2>
          <%= stats?.pending || 0 %>
        </h2>

      </div>

      <div class="stat-card purple">

        <h4>
          In Progress
        </h4>

        <h2>
          <%= stats?.inProgress || 0 %>
        </h2>

      </div>

      <div class="stat-card green">

        <h4>
          Resolved
        </h4>

        <h2>
          <%= stats?.resolved || 0 %>
        </h2>

      </div>

    </section>

    <!-- ===================================== -->
    <!-- FILTERS -->
    <!-- ===================================== -->

    <section class="table-toolbar">

      <input
        type="text"
        class="search-box"
        placeholder="Search complaints..."
      >

      <div class="toolbar-actions">

        <select>

          <option>
            All Status
          </option>

          <option>
            Pending
          </option>

          <option>
            In Progress
          </option>

          <option>
            Resolved
          </option>

        </select>

        <select>

          <option>
            All Priority
          </option>

          <option>
            Low
          </option>

          <option>
            Medium
          </option>

          <option>
            High
          </option>

          <option>
            Critical
          </option>

        </select>

      </div>

    </section>

    <!-- ===================================== -->
    <!-- TABLE -->
    <!-- ===================================== -->

    <section class="content-card">

      <div class="table-wrapper">

        <table>

          <thead>

            <tr>

              <th>
                Ticket
              </th>

              <th>
                Title
              </th>

              <th>
                Category
              </th>

              <th>
                Priority
              </th>

              <th>
                Status
              </th>

              <th>
                Created
              </th>

              <th>
                Action
              </th>

            </tr>

          </thead>

          <tbody>

            <% if (
              complaints &&
              complaints.length
            ) { %>

              <% complaints.forEach(
                complaint => {
              %>

                <tr>

                  <td>

                    #<%= complaint.ticketId %>

                  </td>

                  <td>

                    <%= complaint.title %>

                  </td>

                  <td>

                    <%= complaint.category %>

                  </td>

                  <td>

                    <%= complaint.priority %>

                  </td>

                  <td>

                    <%= complaint.status %>

                  </td>

                  <td>

                    <%= new Date(
                      complaint.createdAt
                    ).toLocaleDateString()
                    %>

                  </td>

                  <td>

                    <a
                      href="/resident/complaints/<%= complaint._id %>"
                      class="btn btn-sm btn-outline"
                    >

                      View

                    </a>

                  </td>

                </tr>

              <% }) %>

            <% } else { %>

              <tr>

                <td
                  colspan="7"
                  class="empty-state"
                >

                  No complaints found.

                </td>

              </tr>

            <% } %>

          </tbody>

        </table>

      </div>

    </section>

    <%- include("../partials/dashboard-footer") %>

  </main>

</div>

<script src="/js/dashboard.js"></script>

</body>

</html>